{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-foundry/authoring/scenario-v1",
  "title": "Scenario v1",
  "type": "object",
  "required": ["schema_version", "scenario_id", "steps"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "scenario_id": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["motion_id", "transition"],
        "properties": {
          "motion_id": { "type": "string", "minLength": 1 },
          "transition": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "enum": ["on_complete", "after_seconds"] },
              "seconds": { "type": "number", "exclusiveMinimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

