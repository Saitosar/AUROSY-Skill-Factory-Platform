{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-foundry/training/reference-trajectory-v1",
  "title": "ReferenceTrajectory v1",
  "type": "object",
  "required": [
    "schema_version",
    "units",
    "robot_model",
    "frequency_hz",
    "root_model",
    "joint_order",
    "joint_positions"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "robot_model": { "type": "string", "minLength": 1 },
    "frequency_hz": { "type": "number", "exclusiveMinimum": 0 },
    "root_model": { "const": "root_not_in_reference" },
    "units": {
      "type": "object",
      "required": ["angle", "time"],
      "properties": {
        "angle": { "const": "radians" },
        "time": { "const": "seconds" }
      },
      "additionalProperties": false
    },
    "joint_order": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[0-9]+$" }
    },
    "joint_positions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "number" }
      }
    },
    "joint_velocities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "number" }
      }
    }
  },
  "additionalProperties": true
}

